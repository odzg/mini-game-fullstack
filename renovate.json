{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "jsonata",
      "description": "Custom manager for devEngines runtime and packageManager within package.json",
      "fileFormat": "json",
      "managerFilePatterns": ["/package.json/"],
      "matchStrings": [
        "devEngines.runtime.{ \"depName\": name, \"currentValue\": version, \"datasource\": name = \"node\" ? \"node-version\" : (name = \"deno\" ? \"deno\" : \"npm\") }",
        "devEngines.packageManager.{ \"depName\": name, \"currentValue\": version, \"depType\": \"packageManager\", \"datasource\": \"npm\" }"
      ]
    }
  ]
}
